<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#E7D8BA8D"
                android:startColor="#FFF6EBD1" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#66C8A56A" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape>
            <gradient
                android:angle="315"
                android:endColor="#66E9D9B6"
                android:startColor="#66FFF8EC" />
            <corners android:radius="10dp" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>
</layer-list>
