<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/background" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#59000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <RelativeLayout
            android:id="@+id/layout_test_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dark_glass_flat"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp">

            <Space
                android:id="@+id/view_test_status_space"
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <ImageView
                android:id="@+id/btn_back_test"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentStart="true"
                android:layout_below="@id/view_test_status_space"
                android:layout_marginTop="6dp"
                android:contentDescription="&#x8FD4;&#x56DE;"
                android:padding="10dp"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/view_test_status_space"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:letterSpacing="0.12"
                android:text="&#x529F;&#x80FD;&#x6D4B;&#x8BD5;"
                android:textColor="#E5C07B"
                android:textSize="19sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dark_glass_flat"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x6D4B;&#x8BD5;&#x622A;&#x56FE;"
                        android:textColor="#F6EFD8"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/iv_test_screenshot"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="12dp"
                        android:adjustViewBounds="true"
                        android:background="@drawable/bg_run_log_console"
                        android:contentDescription="@null"
                        android:padding="6dp"
                        android:scaleType="fitCenter" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_dark_glass_flat"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x6D4B;&#x8BD5;&#x914D;&#x7F6E;"
                        android:textColor="#F6EFD8"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinner_templates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_run_log_console"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:popupBackground="@drawable/bg_run_log_console" />

                    <RadioGroup
                        android:id="@+id/rg_test_scope"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rb_test_scope_full"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="#E5C07B"
                            android:checked="true"
                            android:text="&#x5168;&#x5C4F;&#x8BC6;&#x522B;"
                            android:textColor="#FFFFFF" />

                        <RadioButton
                            android:id="@+id/rb_test_scope_local"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:buttonTint="#E5C07B"
                            android:text="&#x5C40;&#x90E8;&#x8BC6;&#x522B;"
                            android:textColor="#FFFFFF" />
                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_test_scope_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#D9D2C3"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_test_upload"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="#A86E2C"
                            android:text="&#x4E0A;&#x4F20;&#x622A;&#x56FE;"
                            android:textColor="#FFF7E6" />

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <Button
                            android:id="@+id/btn_test_run"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="#6A8F6A"
                            android:text="&#x5F00;&#x59CB;&#x6D4B;&#x8BD5;"
                            android:textColor="#FFF7E6" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_test_replace_template"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="#8B5E34"
                            android:text="&#x4E00;&#x952E;&#x66FF;&#x6362;"
                            android:textColor="#FFF7E6" />

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <Button
                            android:id="@+id/btn_test_restore_template"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="#5E6773"
                            android:text="&#x8FD8;&#x539F;&#x7D20;&#x6750;"
                            android:textColor="#FFF7E6" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_dark_glass_flat"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x6D4B;&#x8BD5;&#x65E5;&#x5FD7;"
                        android:textColor="#F6EFD8"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_run_log_console"
                        android:fillViewport="true"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tv_test_log"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
