<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dark_glass"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_add_stone_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="新增星石"
        android:textColor="#E5C07B"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="点击选择星石"
        android:textColor="#F6D28D"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_add_stone_selected_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_dark_hollow"
        android:gravity="center"
        android:minHeight="44dp"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:text="请选择星石"
        android:textColor="#F6D28D"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="10dp"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <GridLayout
            android:id="@+id/layout_add_stone_names"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="3"
            android:useDefaultMargins="false" />
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="等级"
        android:textColor="#E8E0D0"
        android:textSize="13sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_add_stone_level"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_dark_hollow"
        android:gravity="center_vertical"
        android:hint="默认 1级"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:singleLine="true"
        android:text="1级"
        android:textColor="#F3E9D0"
        android:textColorHint="#80F3E9D0"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_add_stone_cancel"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/btn_dark_hollow"
            android:text="取消"
            android:textColor="#A7A7A7"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_add_stone_confirm"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@drawable/btn_dark_gold"
            android:text="新增"
            android:textColor="#1A1A1A"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
