<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/background" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#59000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <RelativeLayout
            android:id="@+id/layout_my_stone_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dark_glass_flat"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp">

            <Space
                android:id="@+id/view_my_stone_status_space"
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <ImageView
                android:id="@+id/btn_back_my_stone"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentStart="true"
                android:layout_below="@id/view_my_stone_status_space"
                android:layout_marginTop="6dp"
                android:contentDescription="&#x8FD4;&#x56DE;"
                android:padding="10dp"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/view_my_stone_status_space"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:letterSpacing="0.12"
                android:text="&#x6211;&#x7684;&#x661F;&#x77F3;"
                android:textColor="#E5C07B"
                android:textSize="19sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_my_stone_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_run_log_console"
            android:gravity="center"
            android:padding="18dp"
            android:text="&#x6682;&#x672A;&#x751F;&#x6210;&#x661F;&#x77F3;&#x7ED3;&#x679C;"
            android:textColor="#F3E9D0"
            android:textSize="13sp"
            android:visibility="gone" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/layout_my_stone_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/tv_my_stone_updated_at"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_run_log_console"
                    android:padding="14dp"
                    android:textColor="#F3E9D0"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_dark_glass"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="&#x7EDF;&#x8BA1;&#x7ED3;&#x679C;"
                        android:textColor="#E5C07B"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_my_stone_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="#F3E9D0"
                        android:textIsSelectable="true"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layout_my_stone_images_heading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_run_log_heading"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_run_log_accent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="&#x7ED3;&#x679C;&#x56FE;"
                                android:textColor="#F6D28D"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_my_stone_images_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="&#x9ED8;&#x8BA4;&#x6536;&#x8D77;"
                                android:textColor="#D3D3D3"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btn_toggle_my_stone_images"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/btn_dark_hollow"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:text="&#x5C55;&#x5F00;"
                            android:textColor="#E5C07B"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_my_stone_images_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_dark_glass"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/iv_my_stone_result_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:id="@+id/iv_my_stone_result_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layout_my_stone_rows_heading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_run_log_heading"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_run_log_accent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:text="&#x539F;&#x4F4D;&#x7F6E;&#x5C55;&#x793A;"
                                android:textColor="#F6D28D"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_my_stone_rows_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="&#x9ED8;&#x8BA4;&#x6536;&#x8D77;"
                                android:textColor="#D3D3D3"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btn_toggle_my_stone_rows"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/btn_dark_hollow"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:text="&#x5C55;&#x5F00;"
                            android:textColor="#E5C07B"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_my_stone_rows_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_dark_glass"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_my_stone_rows_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="4dp"
                            android:textColor="#F3E9D0"
                            android:textSize="13sp" />

                        <LinearLayout
                            android:id="@+id/layout_my_stone_rows"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
