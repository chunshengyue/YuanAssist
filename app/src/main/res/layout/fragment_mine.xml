<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dark_glass"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_mine_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardBackgroundColor="#33000000"
            app:cardCornerRadius="40dp">

            <ImageView
                android:id="@+id/iv_mine_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_mine_nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x672A;&#x767B;&#x5F55;"
                android:textColor="#E5C07B"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_mine_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ID: --"
                android:textColor="#9E9E9E"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_sync_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingVertical="4dp"
                android:paddingEnd="8dp"
                android:text="&#x91CD;&#x65B0;&#x83B7;&#x53D6;&#x6635;&#x79F0;&#x548C;&#x5934;&#x50CF;"
                android:textColor="#64B5F6"
                android:textSize="11sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_one_click_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="#E5C07B"
                android:text="&#x4E00;&#x952E;&#x521B;&#x5EFA;/&#x767B;&#x5F55;&#x8BE5;&#x8BBE;&#x5907;&#x8D26;&#x53F7;"
                android:textColor="#121212"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_edit_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#9E9E9E" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_my_published_entry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_dark_hollow"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x6211;&#x7684;&#x53D1;&#x5E03;"
                android:textColor="#E5C07B"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x8FDB;&#x5165;"
            android:textColor="#E5C07B"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_my_favorite_entry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_dark_hollow"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x6211;&#x7684;&#x6536;&#x85CF;"
                android:textColor="#E5C07B"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x8FDB;&#x5165;"
            android:textColor="#E5C07B"
            android:textSize="14sp"
            android:paddingStart="8dp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
