<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_job_station_page"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingTop="44dp"
        android:paddingEnd="14dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btn_job_station_list_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_job_station_icon_button"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            android:tint="#7B5B17"
            android:contentDescription="返回" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="作业站"
                android:textColor="#7B5B17"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="从本地 assets/strategy 读取"
                android:textColor="#8A6B2D"
                android:textSize="13sp" />
        </LinearLayout>
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="12dp"
        android:text="先看列表，再点进详情。作者、原作者和原链接仍会在详情页里占位展示。"
        android:textColor="#5A4830"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_job_station_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="18dp"
        android:paddingTop="4dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp" />

    <TextView
        android:id="@+id/tv_job_station_list_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="18dp"
        android:background="@drawable/bg_job_station_card"
        android:gravity="center"
        android:padding="24dp"
        android:text="assets/strategy 下暂时没有可展示的 JSON。"
        android:textColor="#6B5739"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>
