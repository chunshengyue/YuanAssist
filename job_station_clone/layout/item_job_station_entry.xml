<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_job_station_card"
    android:clickable="true"
    android:elevation="2dp"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tv_job_station_item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="2026年04月"
        android:textColor="#7B5B17"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_job_station_item_stage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="关卡：白鹄 / 2026年04月 / 干吉"
        android:textColor="#5F4B2D"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_job_station_item_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:lineSpacingExtra="3dp"
        android:maxLines="3"
        android:text="这里展示作业摘要。"
        android:textColor="#423725"
        android:textSize="14sp" />
</LinearLayout>
